namespace scmoa;

table ShardUpdate {
  shard_id: uint32;
  state: uint8;
  reward: float32;
  done: bool;
  context: [float32];
  specialist_id: uint8; // The "Router" index chosen by the Distiller
}

table HivemindUpdate {
  shards: [ShardUpdate];
  step_id: uint64;
}

table ShardResult {
  shard_id: uint32;
  predicted_state: uint8;
  action: uint8;
}

table HivemindResult {
  results: [ShardResult];
  step_id: uint64;
}

table TopologyMutation {
  command: string;
  step_id: uint64;
}

table Checkpoint {
  filepath: string;
  step_id: uint64;
}

union Payload {
  HivemindUpdate,
  HivemindResult,
  TopologyMutation,
  Checkpoint
}

table Message {
  payload: Payload;
}

root_type Message;
