namespace scmoa;

table ShardUpdate {
  shard_id: uint32;
  state: uint8;
  reward: float32;
  done: bool;
  context: [float32];
  specialist_id: uint8; // The "Router" index chosen by the Distiller
}

table HivemindUpdate {
  shards: [ShardUpdate];
  step_id: uint64;
}

table ShardResult {
  shard_id: uint32;
  predicted_state: uint8;
  action: uint8;
}

table HivemindResult {
  results: [ShardResult];
  step_id: uint64;
}

table TopologyMutation {
  command: string;
  step_id: uint64;
}

table Checkpoint {
  filepath: string;
  step_id: uint64;
}

table Config {
  learning_rate: float32;
  batch_size: uint32;
  hidden_dim: uint32;
  nhead: uint32;
  num_layers: uint32;
  num_specialists: uint32;
  max_seq: uint32;
  entropy_coef: float32;
  mutation_threshold: float32;
}

union Payload {
  HivemindUpdate,
  HivemindResult,
  TopologyMutation,
  Checkpoint,
  Config
}

table Message {
  payload: Payload;
}

root_type Message;
